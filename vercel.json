{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/telegram/retry-pending",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/telegram/webhook",
      "destination": "/api/telegram/webhook"
    },
    {
      "source": "/telegram/status",
      "destination": "/api/telegram/status"
    },
    {
      "source": "/telegram/retry-pending",
      "destination": "/api/telegram/retry-pending"
    },
    {
      "source": "/perseo/import-report",
      "destination": "/api/perseo/import-report"
    },
    {
      "source": "/perseo/audit-closures",
      "destination": "/api/perseo/audit-closures"
    },
    {
      "source": "/perseo/debug-date",
      "destination": "/api/perseo/debug-date"
    }
  ]
}
