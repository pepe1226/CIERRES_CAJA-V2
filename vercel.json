{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/telegram/webhook",
      "destination": "/api/telegram/webhook"
    },
    {
      "source": "/telegram/status",
      "destination": "/api/telegram/status"
    },
    {
      "source": "/telegram/retry-pending",
      "destination": "/api/telegram/retry-pending"
    }
  ],
  "crons": [
    {
      "path": "/api/telegram/retry-pending",
      "schedule": "*/5 * * * *"
    }
  ]
}