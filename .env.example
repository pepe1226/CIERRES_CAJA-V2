# ==============================================================
# Frontend Firebase
# La app usa Firebase Authentication con proveedor Google.
# La configuracion publica del frontend esta en firebase-applet-config.json.
# En Firebase Console debes habilitar Google y autorizar el dominio de Vercel.
# ============================================================== 

# ==============================================================
# Gemini
# ============================================================== 
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ==============================================================
# Telegram
# Nunca pegues el token del bot en el codigo ni en el chat.
# Cargalo como Environment Variable en Vercel.
# ============================================================== 
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# UID Firebase Auth del usuario Google que quedara como creador de registros Telegram.
# Si lo dejas vacio se usara telegram-bot y solo administradores podran editar esos movimientos.
TELEGRAM_CREATED_BY_UID=

# ==============================================================
# Firebase Admin para Vercel Serverless
# Necesario porque el webhook escribe en Firestore desde el backend.
# Recomendado: FIREBASE_SERVICE_ACCOUNT_BASE64.
# Alternativa: FIREBASE_SERVICE_ACCOUNT_JSON.
# ============================================================== 
FIREBASE_PROJECT_ID=gen-lang-client-0181048054
FIRESTORE_DATABASE_ID=ai-studio-1c7e2a21-6400-4184-8dda-2ebe06e9d591
FIREBASE_STORAGE_BUCKET=gen-lang-client-0181048054.firebasestorage.app
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_JSON=
